#!/bin/bash
set -e

if command -v xcrun &>/dev/null; then
  xcrun swift Scripts/generate-fixed-arity.swift --check
else
  swift Scripts/generate-fixed-arity.swift --check
fi

if ! command -v swift-format &>/dev/null || ! command -v swiftlint &>/dev/null; then
  echo "warning: swift-format or swiftlint not found, skipping lint (run: brew install swift-format swiftlint)"
  exit 0
fi

STAGED_SWIFT=()
while IFS= read -r -d '' path; do
  STAGED_SWIFT+=("$path")
done < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.swift')

for path in "${STAGED_SWIFT[@]}"; do
  if ! git diff --quiet -- "$path"; then
    echo "error: staged Swift file also has unstaged changes: $path" >&2
    echo "Stage the complete file or move the unstaged changes before committing." >&2
    exit 1
  fi
done

for path in "${STAGED_SWIFT[@]}"; do
  swift-format format --in-place -- "$path"
  swiftlint lint --fix --quiet "$path"
  git add -- "$path"
done

swift-format lint --strict --recursive Sources Tests
swiftlint lint --strict --quiet
